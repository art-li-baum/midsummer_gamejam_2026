--- !u!114 &1782741996793127396
MonoBehaviour:
  m_ObjectHideFlags: 0
  m_CorrespondingSourceObject: {fileID: 0}
  m_PrefabInstance: {fileID: 0}
  m_PrefabAsset: {fileID: 0}
  m_GameObject: {fileID: 5453618355963449027}
  m_Enabled: 1
  m_EditorHideFlags: 0
  m_Script: {fileID: 11500000, guid: b8711ba45f19e4c4caf655b6ce4173b2, type: 3}
  m_Name: 
  m_EditorClassIdentifier: 
  FirstShiftStarted:
  - Text: Now you're getting the hang of it!
    MessageDelay: 1
    Jitter: 0
    CustomFontSize: 0
    FontSize: 60
  - Text: Check your Order Screen, find the items on the shelves and put it in the
      box.
    MessageDelay: 3
    Jitter: 0
    CustomFontSize: 0
    FontSize: 60
  - Text: Since you're part of the family we assume you know our Catalogue by heart
      <3
    MessageDelay: 2
    Jitter: 0
    CustomFontSize: 0
    FontSize: 60
  - Text: When the package is ready, just press the green button to send it off!
    MessageDelay: 2
    Jitter: 0
    CustomFontSize: 0
    FontSize: 60
  FirstPackageShipped:
  - Text: You're a natural!
    MessageDelay: 1
    Jitter: 0
    CustomFontSize: 0
    FontSize: 0
  - Text: At the end of your shift you will be awarded with Glorbo-Bucks that increase
      your Family Rank :)
    MessageDelay: 2
    Jitter: 0
    CustomFontSize: 0
    FontSize: 0
  - Text: To complete your MANDATORY SERVICE, you will need to collect 9999 Glorbo-Bucks!
    MessageDelay: 2
    Jitter: 0
    CustomFontSize: 0
    FontSize: 0
  - Text: Get Packing! ;)
    MessageDelay: 2
    Jitter: 50
    CustomFontSize: 0
    FontSize: 0
  SecondPackageShipped:
  - Text: At you current rank you will need to complete 3 orders to finish your shift.
      Just one more!
    MessageDelay: 1
    Jitter: 0
    CustomFontSize: 0
    FontSize: 60
